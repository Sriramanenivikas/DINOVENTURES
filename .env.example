# ==========================================
# Environment Variables for Wallet Service
# ==========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Database credentials are loaded from AWS Secrets Manager
# at startup. See SecretsManagerConfig.java for details.
# ==========================================

# AWS Credentials (required locally — on EC2/ECS, use IAM Roles instead)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# Spring Profile (optional: default | prod)
SPRING_PROFILES_ACTIVE=default

# JVM Settings (optional)
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseG1GC

